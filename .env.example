# Copy to .env and fill in values. Never commit .env.
#
# After creating a Supabase project: Settings → Database → copy the URI (direct)
# and pooler strings. Run migrations locally or in CI:
#   DATABASE_URL=... DIRECT_URL=... npx prisma migrate deploy

# Pooled connection (Supabase "Transaction pooler" / port 6543) — Prisma Client / serverless runtime.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — required for migrations (directUrl in prisma/schema.prisma).
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres"

# NextAuth — must match the browser URL exactly (same origin + port as dev server).
# Local: npm run dev serves on port 3109 (see package.json). Production on Vercel: https://ufm.melodoumani.com
NEXTAUTH_URL="http://localhost:3109"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
